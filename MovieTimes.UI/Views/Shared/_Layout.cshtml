<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MovieTimes.UI</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MovieTimes.UI.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var userJson = TempData.Peek("UserLogged")?.ToString();
        System.Text.Json.JsonElement? user = null;
        try
        {
            if (!string.IsNullOrEmpty(userJson) && userJson.StartsWith("{"))
            {
                user = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(userJson);
            }
        }
        catch { user = null; }
    }

    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index" style="color: #ff00ff;">MoviesProject</a>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Cartelera Disponible</a>
                        </li>
                        @if (user.HasValue)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Home" asp-action="Privacy">Panel Usuarios</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="User" asp-action="Index">Mantenimiento (Admin)</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (user.HasValue)
                        {
                            <li class="nav-item d-flex align-items-center">
                                <span class="nav-link text-success fw-bold">
                                    ● Online: @user.Value.GetProperty("Nombre").GetString()
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-controller="User" asp-action="Logout">Salir</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-bold" asp-controller="User" asp-action="Login">Iniciar Sesión</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <script>
            const userId   = '@(user.HasValue ? user.Value.GetProperty("Id").GetInt32() : 0)';
            const userName = '@(user.HasValue ? user.Value.GetProperty("Nombre").GetString() : "")';
    </script>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted position-relative">
        <div class="container">
            &copy; 2026 - MovieTimes.UI - <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>