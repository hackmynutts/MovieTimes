@model MovieTimes.UI.Models.UserAddDTO

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Retro Login - MoviesProject</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
            /* 1. REINICIO TOTAL PARA EVITAR EL ERROR DE LA IMAGEN */
            html, body {
                height: 100%;
                margin: 0;
                padding: 0;
                overflow: hidden; /* Evita scrolls raros */
            }

            body {
                /* Fondo de puntos estilo Memphis */
                background-color: #fff1f8;
                background-image: radial-gradient(#ff6ac1 1px, transparent 1px);
                background-size: 25px 25px;
                display: flex;
                justify-content: center;
                align-items: center;
                font-family: 'Arial Black', sans-serif;
            }

            /* 2. LA TARJETA (CARD) CON ESTILO POP */
            .retro-box {
                background: #fff;
                border: 6px solid #000;
                padding: 40px;
                box-shadow: 15px 15px 0px #6e44ff; /* Sombra morada sólida */
                width: 100%;
                max-width: 450px;
                transform: rotate(-1deg); /* Inclinación "radical" */
            }

            .retro-header {
                background: #f4d35e; /* Amarillo */
                border: 4px solid #000;
                margin: -60px auto 30px auto;
                padding: 10px;
                box-shadow: 6px 6px 0px #000;
                width: fit-content;
            }

                .retro-header h1 {
                    margin: 0;
                    font-size: 1.8rem;
                    color: #000;
                    text-transform: uppercase;
                }

            /* 3. INPUTS Y BOTONES */
            .form-label {
                color: #000;
                text-transform: uppercase;
                font-size: 0.9rem;
                margin-bottom: 10px;
                display: block;
            }

            .retro-input {
                border: 4px solid #000;
                border-radius: 0;
                padding: 12px;
                font-size: 1.1rem;
                background: #9be9ff; /* Cian claro */
                color: #000 !important;
                box-shadow: inset 4px 4px 0px rgba(0,0,0,0.1);
            }

                .retro-input:focus {
                    background: #fff;
                    outline: none;
                    box-shadow: none;
                    border-color: #ff6ac1;
                }

            .btn-retro {
                background: #ff6ac1; /* Rosa */
                color: #000;
                border: 4px solid #000;
                border-radius: 0;
                width: 100%;
                padding: 15px;
                font-size: 1.3rem;
                font-weight: 900;
                text-transform: uppercase;
                box-shadow: 6px 6px 0px #000;
                margin-top: 20px;
                transition: 0.1s;
            }

                .btn-retro:hover {
                    transform: translate(3px, 3px);
                    box-shadow: 0px 0px 0px #000;
                    background: #f4d35e;
                }

            .error-msg {
                background: #ff0000;
                color: #fff;
                border: 3px solid #000;
                margin-top: 20px;
                padding: 5px;
                font-size: 0.8rem;
            }
    </style>
</head>
<body>

    <div class="retro-box">
        <div class="retro-header">
            <h1>LOGIN ACCESS</h1>
        </div>

        <form asp-action="Login" method="post">
            <div class="mb-3 text-start">
                <label class="form-label">Terminal Email:</label>
                <input type="email" name="email" class="form-control retro-input" placeholder="USER@RETRO.COM" required />
            </div>

            <div class="mb-3 text-start">
                <label class="form-label">Password:</label>
                <input type="password" name="password" class="form-control retro-input"
                       placeholder="••••••••" required />
            </div>

            <button type="submit" class="btn btn-retro">VALIDATE</button>
        </form>

        @if (ViewBag.Error != null)
        {
            <div class="error-msg text-center">
                ⚠ ERROR: @ViewBag.Error
            </div>
        }
    </div>

</body>
</html>